<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:SemestralniPraceNovak.ViewModels"
			 xmlns:models="using:SemestralniPraceNovak.Models"
			 x:Class="SemestralniPraceNovak.Controls.BracketControl"
			 x:DataType="vm:BracketViewModel"
			 MinHeight="120">
	<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
		<ItemsControl ItemsSource="{Binding Rounds}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal" Spacing="24"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>

			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<StackPanel Spacing="12" Margin="10">
						<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>

						<ItemsControl ItemsSource="{Binding Matches}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:Match">
									<Border Background="#F2F2F2"
											BorderBrush="#CCCCCC"
											BorderThickness="1"
											Padding="10"
											CornerRadius="8"
											Width="200"
											Margin="0,5">
										<StackPanel Spacing="6">
											<Grid ColumnDefinitions="*, 45">
												<TextBlock Text="{Binding Team1.Name, FallbackValue='---'}"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis"/>
												<TextBox Grid.Column="1"
														 Text="{Binding Score1}"
														 Height="26" Padding="2"
														 FontSize="12"
														 TextAlignment="Center"/>
											</Grid>

											<TextBlock Text="vs" FontSize="10" HorizontalAlignment="Center" Foreground="Gray"/>
											<Grid ColumnDefinitions="*, 45">
												<TextBlock Text="{Binding Team2.Name, FallbackValue='---'}"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis"/>
												<TextBox Grid.Column="1"
														 Text="{Binding Score2}"
														 Height="26" Padding="2"
														 FontSize="12"
														 TextAlignment="Center"/>
											</Grid>


											<Button Content="Potvrdit výsledek"
													HorizontalAlignment="Stretch"
													HorizontalContentAlignment="Center"
													FontSize="11"
													Padding="4"
													Margin="0,4,0,0"
													Background="#28A745"
													Foreground="White"

													Command="{Binding DataContext.AdvanceWinnerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

													CommandParameter="{Binding}"/>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</ScrollViewer>
</UserControl>